      </div>

      {/* Navbar */}
      <header className="fixed top-4 left-1/2 z-40 -translate-x-1/2 px-4 w-full max-w-4xl">
        <nav className="glass-strong flex items-center gap-1 rounded-full px-2 py-1.5 shadow-glass">
